<Window 
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:lang="clr-namespace:qBittorrentCompanion.Resources"
	mc:Ignorable="d"
	Width="660"
	SizeToContent="Height"
	x:Class="qBittorrentCompanion.Views.OwnAboutWindow"
	WindowStartupLocation="CenterOwner"
	Title="{x:Static lang:Resources.OwnAboutWindow_AboutQbittorrentCompanion}"
	TransparencyLevelHint="AcrylicBlur"
	Background="{DynamicResource SystemAltMediumColor}"
	xmlns:cc="clr-namespace:qBittorrentCompanion.CustomControls"
	xmlns:service="clr-namespace:qBittorrentCompanion.Services"
	CanResize="False"
	ExtendClientAreaToDecorationsHint="True">
	<StackPanel Spacing="8" Margin="12">
		<TextBlock DockPanel.Dock="Top" Text="{x:Static lang:Resources.OwnAboutWindow_AboutQbittorrentCompanion}" Classes="Title"/>
		<cc:SimpleHtmlTextBlock x:Name="FirstParagraphSimpleHtmlTextBlock" LinkColor="{DynamicResource SystemAccentColorDark1}" TextWrapping="Wrap"/>
		<cc:SimpleHtmlTextBlock x:Name="SecondParaphSimpleHtmlTextBlock" LinkColor="{DynamicResource SystemAccentColorDark1}" TextWrapping="Wrap" />
		<cc:SimpleHtmlTextBlock x:Name="ThirdParagraphSimpleHtmlTextBlock" LinkColor="{DynamicResource SystemAccentColorDark1}" TextWrapping="Wrap" />
		
		<TextBlock Margin="0 15 0 0" FontWeight="Bold">
			<Run Text="qBittorrent Companion -"/>
			<Run Text="v"/><Run Text="{Binding Source={x:Static service:UpdateService.Instance}, Path=CurrentVersion, Mode=TwoWay}"/>
		</TextBlock>
		<DockPanel DockPanel.Dock="Bottom">
			<TextBlock Grid.Column="0" TextWrapping="Wrap" Text="{x:Static lang:Resources.OwnAboutWindow_AuthorMe}"/>
			<Image Grid.Column="1" Height="20" Margin="8 0" VerticalAlignment="Center" HorizontalAlignment="Left" Source="avares://qBittorrentCompanion/Assets/Flags/nl.png"/>
		</DockPanel>
		<TextBlock DockPanel.Dock="Top" Margin="0 0 0 0" TextWrapping="Wrap" Text="{x:Static lang:Resources.OwnAboutWindow_LicenseMit}"/>

		<Button 
			DockPanel.Dock="Bottom" 
			HorizontalAlignment="Right"
			Margin="0 0 -2 0"
			Click="CloseButton_Click"
			IsCancel="True"
			Content="{x:Static lang:Resources.Global_CloseWindow}"
			/>
	</StackPanel>
</Window>
